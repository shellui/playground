{
  "name": "shellui-playground",
  "version": "0.3.0",
  "description": "A playground for ShellUI — demo deployed to GitHub Pages",
  "type": "module",
  "scripts": {
    "start": "shellui start",
    "build": "shellui build && pnpm -C app build",
    "serve:dist": "node tools/serve/serve.js",
    "format": "pnpm exec prettier --write .",
    "format:check": "pnpm exec prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": "pnpm exec prettier --write --ignore-unknown"
  },
  "author": "ShellUI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shellui/shellui-playground.git"
  },
  "packageManager": "pnpm@10.30.0",
  "dependencies": {
    "@shellui/cli": "^0.3.0",
    "@shellui/core": "^0.3.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  }
}
